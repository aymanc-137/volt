{#
| Variable                          | Type     | Description                                                          |
|-----------------------------------|----------|----------------------------------------------------------------------|
| component.title                   | ?string  | Main title                                                           |
| component.sub_title               | ?string  | Subtitle                                                             |
| component.enable_gradient_title   | bool     | Gradient across full title                                           |
| component.enable_gradient_word    | bool     | Gradient on a specific word                                          |
| component.gradient_word           | ?string  | Word to apply gradient to                                            |
| component.before_image            | string   | Image shown on the right of the divider                              |
| component.after_image             | string   | Image shown on the left of the divider                               |
| component.before_label            | ?string  | Caption over the "before" image                                      |
| component.after_label             | ?string  | Caption over the "after" image                                       |
| component.product_image           | ?string  | Product image shown above the body text                              |
| component.body_text               | ?string  | Paragraph beneath the comparison image                               |
| component.link                    | ?string  | Variable-list link (product/category/brand/custom)                   |
| component.link_text               | ?string  | Button label                                                         |
| component.slas_hbg                | bool     | Enable diagonal-lines background                                     |
| component.slas_hbg_type           | string   | 'inclined' / 'vertical' / 'horizontal'                               |
| component.marquee                 | bool     | Enable marquee decorative text                                       |
| component.enable_border           | bool     | Top/bottom borders on the section                                    |
| component.enable_glow             | string   | 'none' / 'circles' / 'sides' / 'top_bottom' / 'left' / 'right' / 'top' / 'bottom' |
| position                          | int      | Component position in the page                                       |
#}

{% set uid = 'ba-' ~ (position | default(random())) %}
{% set title = component.title | default('') %}
{% set sub_title = component.sub_title | default('') %}
{% set before_image = component.before_image | default('') %}
{% set after_image = component.after_image | default('') %}
{% set before_label = component.before_label | default('') %}
{% set after_label = component.after_label | default('') %}
{% set body_text = component.body_text | default('') %}
{% set link_text = component.link_text | default('') %}
{% set product_image = component.product_image | default('') %}

{# ---- Title controls (inline-applied to preserve this component's layout) ---- #}
{% set tc_size = component.title_size | default(36) %}
{% set tc_size = tc_size > 0 ? tc_size : 36 %}
{% set tc_sub = component.sub_title_size | default(18) %}
{% set tc_sub = tc_sub > 0 ? tc_sub : 18 %}
{% set tc_underline = component.enable_title_underline ?? true %}
{% set tc_font = (component.title_use_decorative_font ?? true) ? 'font-alshohadaa' : '' %}
{% set tc_color_type = component.title_color_type | default('default') %}
{% if tc_color_type == 'primary' %}
    {% set tc_color_style = 'color: var(--color-primary);' %}
{% elseif tc_color_type == 'custom' %}
    {% set tc_color_style = 'color: ' ~ (component.title_color | default('#2C3E50')) ~ ';' %}
{% else %}
    {% set tc_color_style = '' %}
{% endif %}
{% set tc_size_style = 'font-size: clamp(' ~ (tc_size * 0.6)|round ~ 'px, 6vw, ' ~ tc_size ~ 'px);' %}
{% set tc_sub_style = 'font-size: clamp(' ~ (tc_sub * 0.8)|round ~ 'px, 2.5vw, ' ~ tc_sub ~ 'px);' %}
{% set tc_hl_type = component.highlight_word_color_type | default('gradient') %}
{% if tc_hl_type == 'primary' %}
    {% set tc_hl_attr = 'style="color: var(--color-primary)"' %}
{% elseif tc_hl_type == 'custom' %}
    {% set tc_hl_attr = 'style="color: ' ~ (component.highlight_word_color | default('#FF3B3B')) ~ '"' %}
{% else %}
    {% set tc_hl_attr = 'class="bg-gradient-to-r from-primary to-scandary bg-clip-text text-transparent"' %}
{% endif %}

{% set slashbg = component.slas_hbg ?? false %}
{% set marquee = component.marquee ?? false %}
{% set marqueetext = component.marqueetext | default('نظافة /// لمعان /// حماية') %}
{% set enable_border = component.enable_border ?? false %}
{% set glow_type = component.enable_glow | default('none') %}
{% set glow_use_theme = component.glow_use_theme_colors ?? true %}
{% set glow_c1 = glow_use_theme ? 'var(--color-primary)'  : (component.glow_color_1 ?? 'var(--color-primary)') %}
{% set glow_c2 = glow_use_theme ? 'var(--color-scandary)' : (component.glow_color_2 ?? 'var(--color-scandary)') %}
{% set marquee_text_position = component.marquee_text_position | default('both') %}
{% set marquee_is_moving = component.marquee_is_moving %}
{% set marquee_text_size = component.marquee_text_size | default('8') %}
{% set slas_hbg_size = component.slas_hbg_size | default('20') %}
{% set slas_hbg_use_primary_color = component.slas_hbg_use_primary_color ?? false %}
{% set slas_hbg_color = (component.slas_hbg_color | default('#000000')) ~ '1A' %}
{% set slas_hbg_type = component.slas_hbg_type | default('inclined') %}
{% set slas_angle = slas_hbg_type == 'vertical' ? '90' : (slas_hbg_type == 'horizontal' ? '0' : '135') %}

{% if before_image and after_image %}
<section data-volt-component="home.before-after"
  id="{{ uid }}-section"
  class=" s-block--before-after {{ enable_border ? 'border-y border-[var(--color-primary)]' : '' }} {{ slashbg ? 'slash-bg-' ~ position ~ ' dynamic-bg-color' : '' }}"
>

  <style>
    #{{ uid }}-section {
      position: relative;
      overflow: hidden;
      padding: 4rem 1rem;
    }

    #{{ uid }}-wrap {
      max-width: none;
      width: 100%;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2.5rem;
      /* Sit above the decorative glow overlays (z-index:0). Without this the
         glow paints over the "before" image (z-index:auto) while the "after"
         image (z-index:2) stays on top — an inconsistent stack. */
      position: relative;
      z-index: 1;
    }
    @media (min-width: 768px) {
      #{{ uid }}-wrap {
        flex-direction: row;
        align-items: center;
        gap: 3rem;
      }
      #{{ uid }}-stage { flex: 1 1 auto; min-width: 0; width: auto; }
      #{{ uid }}-body  { flex: 0 0 35%; min-width: 0; margin: 0; text-align: start; max-width: none; }
      #{{ uid }}-product-img { margin-inline: 0; }
    }

    #{{ uid }}-stage {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 10;
      border-radius: 1rem;
      overflow: hidden;
      user-select: none;
      box-shadow: 0 25px 60px rgba(0, 0, 0, .2);
      background: #000;
    }

    #{{ uid }}-stage img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      pointer-events: none;
      -webkit-user-drag: none;
    }

    #{{ uid }}-after-img {
      clip-path: inset(0 50% 0 0);
      -webkit-clip-path: inset(0 50% 0 0);
      will-change: clip-path;
      z-index: 2;
    }

    #{{ uid }}-divider {
      position: absolute;
      top: 0;
      bottom: 0;
      left: 50%;
      width: 3px;
      background: #fff;
      box-shadow: 0 0 12px rgba(0, 0, 0, .35);
      transform: translateX(-50%);
      pointer-events: none;
      z-index: 3;
    }

    #{{ uid }}-handle {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 3rem;
      height: 3rem;
      border-radius: 9999px;
      background: #fff;
      color: #111;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
      font-size: 1.25rem;
      font-weight: 700;
      line-height: 1;
      cursor: ew-resize;
      box-shadow: 0 6px 20px rgba(0, 0, 0, .35);
      z-index: 4;
      touch-action: none;
      user-select: none;
    }
    #{{ uid }}-handle::before { content: '‹'; }
    #{{ uid }}-handle::after  { content: '›'; }

    #{{ uid }}-label-before,
    #{{ uid }}-label-after {
      position: absolute;
      top: 1rem;
      padding: .35rem .9rem;
      border-radius: 9999px;
      font-size: .8rem;
      font-weight: 600;
      letter-spacing: .05em;
      background: rgba(0, 0, 0, .55);
      color: #fff;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      z-index: 2;
    }
    #{{ uid }}-label-before { right: 1rem; }
    #{{ uid }}-label-after  { left: 1rem; }

    #{{ uid }}-body {
      max-width: 42rem;
      margin: 0;
      text-align: center;
    }
    #{{ uid }}-body p {
      font-size: 1rem;
      line-height: 1.8;
      margin: 0 0 1.5rem;
    }
    #{{ uid }}-product-img {
      display: block;
      max-width: 16rem;
      max-height: 14rem;
      width: auto;
      height: auto;
      margin: 0 auto 1.5rem;
      object-fit: contain;
      filter: drop-shadow(0 20px 30px rgba(0, 0, 0, .35));
    }

    /* Shrink the product image on small screens */
    @media (max-width: 640px) {
      #{{ uid }}-product-img { max-width: 9rem; max-height: 8rem; margin-bottom: 1rem; }
    }
    @media (max-width: 400px) {
      #{{ uid }}-product-img { max-width: 7rem; max-height: 6.5rem; }
    }

    #{{ uid }}-cta {
      display: inline-block;
      padding: .8rem 1.75rem;
      border-radius: var(--border-radius);
      background: var(--color-primary, #7c3aed);
      color: #fff;
      font-weight: 600;
      text-decoration: none;
      transition: transform .2s ease, opacity .2s ease;
    }
    #{{ uid }}-cta:hover { transform: translateY(-2px); opacity: .92; }
  </style>

  {% if marquee %}
    {% if marquee_text_position == 'top' or marquee_text_position == 'both' %}
      <div class="styleish-text absolute top-10 left-0 w-full opacity-10 pointer-events-none select-none overflow-hidden" dir="ltr">
        <div
          style="font-size: {{ marquee_text_size }}rem; line-height: 1;"
          class="{{ marquee_is_moving ? 'marquee-reverse-sections' : '' }} flex whitespace-nowrap w-max"
        >
          <span class="font-alshohadaa font-bold display-text whitespace-nowrap px-4">
            {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}
          </span>
          <span class="font-alshohadaa font-bold display-text whitespace-nowrap px-4">
            {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}
          </span>
        </div>
      </div>
    {% endif %}

    {% if marquee_text_position == 'bottom' or marquee_text_position == 'both' %}
      <div class="styleish-text absolute bottom-10 left-0 w-full opacity-10 pointer-events-none select-none overflow-hidden" dir="ltr">
        <div
          style="font-size: {{ marquee_text_size }}rem; line-height: 1;"
          class="{{ marquee_is_moving ? 'marquee-content-sections' : '' }} flex whitespace-nowrap w-max"
        >
          <span class="font-alshohadaa font-bold display-text whitespace-nowrap px-4">
            {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}
          </span>
          <span class="font-alshohadaa font-bold display-text whitespace-nowrap px-4">
            {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}
          </span>
        </div>
      </div>
    {% endif %}
  {% endif %}

  {% if title and component.enable_gradient_word and component.gradient_word %}
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        var titleEl = document.getElementById('{{ uid }}-title');
        if (titleEl) {
          var word = '{{ component.gradient_word|e('js') }}';
          var regex = new RegExp('(' + word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
          titleEl.innerHTML = titleEl.innerHTML.replace(
            regex,
            '<span {{ tc_hl_attr|raw }}>$1</span>'
          );
        }
      });
    </script>
  {% endif %}

  <div id="{{ uid }}-wrap">

    <div id="{{ uid }}-stage" data-ba-stage>
      {# Before image (underneath, always fully visible) #}
      <img src="{{ before_image }}" alt="{{ before_label }}" />

      {# After image (stacked on top, clipped to the left portion) #}
      <img id="{{ uid }}-after-img" src="{{ after_image }}" alt="{{ after_label }}" />

      {% if before_label %}<div id="{{ uid }}-label-before">{{ before_label }}</div>{% endif %}
      {% if after_label  %}<div id="{{ uid }}-label-after">{{ after_label }}</div>{% endif %}

      <div id="{{ uid }}-divider" data-ba-divider></div>
      <button
        type="button"
        id="{{ uid }}-handle"
        data-ba-handle
        aria-label="{{ trans('blocks.home.volt.before_after.drag_hint')|e('html_attr') }}"
      ></button>
    </div>

    {% if title or sub_title or product_image or body_text or link_text %}
      <div id="{{ uid }}-body" class="dynamic-text-color">
        {% if title %}
          {% if component.enable_gradient_title %}
            <h2 class="{{ tc_font }} mb-2 bg-gradient-to-r from-primary to-scandary bg-clip-text text-transparent" style="{{ tc_size_style }}">{{ title }}</h2>
          {% elseif component.enable_gradient_word and component.gradient_word %}
            <h2 id="{{ uid }}-title" class="{{ tc_font }} mb-2 dynamic-text-color" style="{{ tc_size_style }} {{ tc_color_style }}">{{ title }}</h2>
          {% else %}
            <h2 class="{{ tc_font }} mb-2 dynamic-text-color" style="{{ tc_size_style }} {{ tc_color_style }}">{{ title }}</h2>
          {% endif %}
          {% if tc_underline %}<span class="navbar-underline"></span>{% endif %}
        {% endif %}
        {% if sub_title %}<p class="mb-4 opacity-80 dynamic-text-color" style="{{ tc_sub_style }}">{{ sub_title }}</p>{% endif %}
        {% if product_image %}
          <img id="{{ uid }}-product-img" src="{{ product_image }}" alt="" loading="lazy" />
        {% endif %}
        {% if body_text %}<p class="dynamic-text-color">{{ body_text }}</p>{% endif %}
        {% if link_text %}
          {% set link_url = component.link %}
          {% if link_url is iterable %}{% set link_url = link_url.url | default('') %}{% endif %}
          <a id="{{ uid }}-cta" href="{{ link_url | default('#') }}">{{ link_text }}</a>
        {% endif %}
      </div>
    {% endif %}

  </div>

  {% if glow_type == 'circles' %}
    <div style="position:absolute; top:15%; left:25%; width:16rem; height:16rem; border-radius:9999px; filter:blur(64px); opacity:.6; pointer-events:none; z-index:0; background-color:{{ glow_c1 }};"></div>
    <div style="position:absolute; bottom:15%; right:25%; width:14rem; height:14rem; border-radius:9999px; filter:blur(64px); opacity:.6; pointer-events:none; z-index:0; background-color:{{ glow_c2 }};"></div>
    <div style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:13rem; height:13rem; border-radius:9999px; filter:blur(64px); opacity:.6; pointer-events:none; z-index:0; background-color:{{ glow_c1 }};"></div>
  {% elseif glow_type == 'sides' %}
    <div style="position:absolute; top:0; bottom:0; left:0; width:40%; pointer-events:none; z-index:0; background:linear-gradient(to right, {{ glow_c1 }}, transparent); opacity:.22;"></div>
    <div style="position:absolute; top:0; bottom:0; right:0; width:40%; pointer-events:none; z-index:0; background:linear-gradient(to left, {{ glow_c2 }}, transparent); opacity:.22;"></div>
  {% elseif glow_type == 'top_bottom' %}
    <div style="position:absolute; left:0; right:0; top:0; height:45%; pointer-events:none; z-index:0; background:linear-gradient(to bottom, {{ glow_c1 }}, transparent); opacity:.22;"></div>
    <div style="position:absolute; left:0; right:0; bottom:0; height:45%; pointer-events:none; z-index:0; background:linear-gradient(to top, {{ glow_c2 }}, transparent); opacity:.22;"></div>
  {% elseif glow_type == 'left' %}
    <div style="position:absolute; top:0; bottom:0; left:0; width:40%; pointer-events:none; z-index:0; background:linear-gradient(to right, {{ glow_c1 }}, transparent); opacity:.25;"></div>
  {% elseif glow_type == 'right' %}
    <div style="position:absolute; top:0; bottom:0; right:0; width:40%; pointer-events:none; z-index:0; background:linear-gradient(to left, {{ glow_c1 }}, transparent); opacity:.25;"></div>
  {% elseif glow_type == 'top' %}
    <div style="position:absolute; left:0; right:0; top:0; height:45%; pointer-events:none; z-index:0; background:linear-gradient(to bottom, {{ glow_c1 }}, transparent); opacity:.25;"></div>
  {% elseif glow_type == 'bottom' %}
    <div style="position:absolute; left:0; right:0; bottom:0; height:45%; pointer-events:none; z-index:0; background:linear-gradient(to top, {{ glow_c1 }}, transparent); opacity:.25;"></div>
  {% endif %}
</section>

<style>
  {% if slas_hbg_use_primary_color %}
    .slash-bg-{{ position }} {
      background: linear-gradient(
        {{ slas_angle }}deg,
        var(--color-primary-10) 25%,
        rgba(0, 0, 0, 0) 25%,
        rgba(0, 0, 0, 0) 50%,
        var(--color-primary-10) 50%,
        var(--color-primary-10) 75%,
        rgba(0, 0, 0, 0) 75%
      );
      background-size: {{ slas_hbg_size }}px {{ slas_hbg_size }}px;
    }
  {% else %}
    .slash-bg-{{ position }} {
      background: linear-gradient(
        {{ slas_angle }}deg,
        {{ slas_hbg_color }} 25%,
        rgba(0, 0, 0, 0) 25%,
        rgba(0, 0, 0, 0) 50%,
        {{ slas_hbg_color }} 50%,
        {{ slas_hbg_color }} 75%,
        rgba(0, 0, 0, 0) 75%
      );
      background-size: {{ slas_hbg_size }}px {{ slas_hbg_size }}px;
    }
  {% endif %}
</style>

<script>
  (function () {
    function init() {
      var stage    = document.getElementById('{{ uid }}-stage');
      var afterImg = document.getElementById('{{ uid }}-after-img');
      var divider  = document.getElementById('{{ uid }}-divider');
      var handle   = document.getElementById('{{ uid }}-handle');
      if (!stage || !afterImg || !handle) return;
      if (stage.dataset.baInit === '1') return;
      stage.dataset.baInit = '1';

      var dragging = false;
      var currentPct = 50;

      function setPosition(percent) {
        percent = Math.max(0, Math.min(100, percent));
        currentPct = percent;
        var clip = 'inset(0 ' + (100 - percent) + '% 0 0)';
        afterImg.style.clipPath = clip;
        afterImg.style.webkitClipPath = clip;
        divider.style.left = percent + '%';
        handle.style.left  = percent + '%';
      }

      function pointerXToPercent(clientX) {
        var rect = stage.getBoundingClientRect();
        return ((clientX - rect.left) / rect.width) * 100;
      }

      function start(e) {
        dragging = true;
        document.body.style.cursor = 'ew-resize';
        move(e);
      }

      function move(e) {
        if (!dragging) return;
        var x = (e.touches && e.touches[0]) ? e.touches[0].clientX : e.clientX;
        if (x == null) return;
        setPosition(pointerXToPercent(x));
        if (e.cancelable) e.preventDefault();
      }

      function end() {
        dragging = false;
        document.body.style.cursor = '';
      }

      handle.addEventListener('mousedown', start);
      handle.addEventListener('touchstart', start, { passive: false });
      stage.addEventListener('mousedown', start);
      stage.addEventListener('touchstart', start, { passive: false });

      window.addEventListener('mousemove', move);
      window.addEventListener('touchmove', move, { passive: false });
      window.addEventListener('mouseup', end);
      window.addEventListener('touchend', end);
      window.addEventListener('touchcancel', end);

      // keyboard support
      handle.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowLeft')  setPosition(currentPct - 4);
        if (e.key === 'ArrowRight') setPosition(currentPct + 4);
      });

      setPosition(50);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
{% endif %}
