{#
| Variable                        | Type     | Description                                                                  |
|---------------------------------|----------|------------------------------------------------------------------------------|
| component                       | object   | Contains merchant settings for fields from twilight.json `component` section |
| component.slides                | object[] | list of slides                                                                |
| component.slides[].image        | string   | URL of slide image                                                            |
| component.slides[].image_alt    | ?string  | Accessible alternative text                                                   |
| component.slides[].title_part1  | ?string  | First part of title (before gradient)                                        |
| component.slides[].title_gradient | ?string | Middle part with gradient (primary to secondary color)                       |
| component.slides[].title_part3  | ?string  | Last part of title (after gradient)                                          |
| component.slides[].description  | ?string  | Slide description                                                             |
| component.slides[].button_label | ?string  | CTA button label                                                              |
| component.slides[].button_url   | ?string  | CTA button link                                                               |
| component.slides[].content_alignment | ?string  | Content alignment (start, center, end)                                        |
| component.animation_type        | ?string  | Animation type: slide or fade                                                |
| component.autoplay              | ?boolean | Enable auto-play                                                              |
| component.autoplay_delay        | ?int     | Auto-play delay in seconds                                                    |
| position                        | int      | Sorting number start from zero                                                |
#}
{% set slides = component.slides  %}
{% set animation_type = component.animation_type  %}
{% set autoplay = component.autoplay ?? false %}
{% set autoplay_delay = component.autoplay_delay ?? 5 %}
{% set show_car_search = component.show_car_search | default(false) %}
{% set car_search_at_bottom = component.car_search_at_bottom ?? false %}
{% set car_search_horizontal = component.car_search_horizontal_dropdowns ?? false %}

{% set block_id = 'enhanced-image-carousel-' ~ position %}
 <section dir="ltr" class="h-[58dvh] md:h-[65dvh] lg:h-[80dvh] xl:h-[100dvh] w-full relative" id="{{ block_id }}">
    <div
        class="enhanced-carousel h-full  relative group/carousel"
        data-enhanced-carousel
        data-carousel-id="{{ block_id }}"
        data-animation-type="{{ animation_type }}"
        data-autoplay="{{ autoplay ? 'true' : 'false' }}"
        data-autoplay-delay="{{ autoplay_delay * 1000 }}"
    >
        <div class="relative overflow-hidden h-full dark:bg-dark-box-background">
            <div class="{% if animation_type == 'fade' %}relative{% else %}flex transition-transform{% endif %} h-full duration-500 ease-in-out will-change-transform" data-carousel-track>
                {% for slide in slides %}
                {% set alignment = slide.content_alignment ?? 'center' %}
                    
                    {% set alignment_class = {
                        'start': 'items-start text-left rtl:text-right',
                        'center': 'items-center text-center',
                        'end': 'items-end text-right rtl:text-left'
                    } %} 

              
                    {# [alignment] ?? 'items-center text-center' #}
                    <article class="{% if animation_type == 'fade' %}absolute inset-0 opacity-0 transition-opacity duration-500{% else %}relative w-full shrink-0{% endif %} h-full" data-carousel-slide>
                        {% set media_type = slide.media_type[0] ?? 'image' %}

                        {% if media_type == 'video' and slide.video_url %}
                            <video
                                class="h-full w-full object-cover"
                                data-lazy-video="{{ slide.video_url }}"
                                {% if slide.video_poster %}poster="{{ slide.video_poster }}"{% endif %}
                                loop
                                muted
                                playsinline
                                preload="none"
                                aria-label="{{ (slide.image_alt ?: 'carousel-video-' ~ loop.index)|e('html_attr') }}"
                            >
                                <source data-src="{{ slide.video_url }}" type="video/mp4">
                                متصفحك لا يدعم تشغيل الفيديو
                            </video>
                        {% else %}
                            <img
                                class="h-full w-full object-cover"
                                src="{{ slide.image }}"
                                alt="{{ (slide.image_alt ?: slide.title ?: 'carousel-slide-' ~ loop.index)|e('html_attr') }}"
                                loading="lazy"
                                decoding="async"
                            >
                        {% endif %}
                        {# <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div> #}
                        <div class="absolute inset-0">
                            <div dir="rtl" class="
                            bg-gradient-to-l dark:from-[var(--color-dark-page-background)] 
                            from-[var(--color-light-page-background)] 
                            to-transparent
                            flex h-full w-full px-6 py-1 sm:px-12 sm:py-10 md:px-16 lg:px-20">
                                <div class="flex {{ show_car_search ? 'mt-14 sm:mt-16 mb-auto' : 'my-auto' }} w-full max-w-2xl flex-col gap-2 sm:gap-4 dynamic-text-color {{alignment_class[alignment[0]] ?? 'items-center text-center'}}">
                                    {% if slide.title_part1 or slide.title_gradient or slide.title_part3 %}
                                        <h3 class="font-alshohadaa text-xl sm:text-2xl md:text-4xl lg:text-6xl md:leading-20 font-semibold opacity-0" data-carousel-text="title">
                                            {% if slide.title_part1 %}
                                                <span>{{ slide.title_part1 }}</span>
                                            {% endif %}
                                            {% if slide.title_gradient %}
                                                <span class="bg-gradient-to-r  from-primary to-scandary bg-clip-text text-transparent">{{ slide.title_gradient }}</span>
                                            {% endif %}
                                            {% if slide.title_part3 %}
                                                <span>{{ slide.title_part3 }}</span>
                                            {% endif %}
                                        </h3>
                                    {% endif %}
                                    {% if slide.description %}
                                        <p class="text-sm sm:text-base md:text-lg lg:text-xl dynamic-text-color opacity-0" data-carousel-text="description">{{ slide.description }}</p>
                                    {% endif %}
                                    {% if slide.button_label and slide.button_url %}
                                        <div class="pt-2 sm:pt-4 opacity-0" data-carousel-text="button">
                                            <a class="hover-glow transition-all duration-300" href="{{ slide.button_url }}" >
                                                <div class="inline-flex items-center gap-2 justify-center btn btn--primary px-4 py-2 sm:px-6 sm:py-3 md:px-8 md:py-4 text-sm sm:text-base font-semibold uppercase tracking-wide hover:scale-110 cursor-pointer">
                                                    {{ slide.button_label }}
                                                    <i class="sicon-arrow-right rtl:rotate-180"></i>
                                                </div>
                                            </a>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
            {% if slides|length > 1 %}
                {# Navigation Buttons #}
                <button
                    type="button"
                    class="group absolute top-1/2 left-4 hidden h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/80 text-primary shadow-lg transition-all opacity-0 group-hover/carousel:opacity-100 hover:bg-white focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 md:flex"
                    data-carousel-prev
                    aria-label="السابق"
                >
                    <span class="sr-only">السابق</span>
                    <i class="sicon-arrow-left text-xl transition group-hover:-translate-x-1"></i>
                </button>
                <button
                    type="button"
                    class="group absolute top-1/2 right-4 hidden h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/80 text-primary shadow-lg transition-all opacity-0 group-hover/carousel:opacity-100 hover:bg-white focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 md:flex"
                    data-carousel-next
                    aria-label="التالي"
                >
                    <span class="sr-only">التالي</span>
                    <i class="sicon-arrow-right text-xl transition group-hover:translate-x-1"></i>
                </button>

                {# Indicator Dots - Positioned at bottom center #}
                <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex items-center justify-center gap-2 z-10" data-carousel-dots>
                    {% for slide in slides %}
                        <button
                            type="button"
                            class="h-2.5 w-2.5 rounded-full bg-white/40 transition hover:bg-white/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-white"
                            data-carousel-dot="{{ loop.index0 }}"
                            aria-label="انتقال إلى الشريحة {{ loop.index }}"
                        ></button>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

    {% if show_car_search %}
    {% if not car_search_at_bottom %}
        <style>
            @media (max-width: 1023px) {
                #{{ block_id }} + * { padding-top: 10rem; }
            }
        </style>
    {% endif %}
    {# Single car-search box overlaid on the carousel — JS populates via salla.api #}
    {% if car_search_at_bottom %}
        <div class="flex absolute
                    bottom-0 left-0 right-0 w-full rounded-none
                    lg:left-1/2 lg:right-auto lg:-translate-x-1/2 lg:w-auto lg:max-w-5xl lg:rounded-2xl lg:mb-4
                    z-20 max-h-[45%] lg:max-h-[35%] flex-col overflow-hidden
                    shadow-2xl
                    dark:bg-dark-foreground/50 backdrop-blur-md{% if car_search_horizontal %} home-car-search--horizontal{% endif %}"
             dir="rtl"
             data-home-car-search="{{ position }}">
        </div>
    {% else %}
        <div class="flex absolute
                    bottom-0 translate-y-1/2 left-0 right-0 w-full rounded-none
                    lg:bottom-auto lg:top-1/2 lg:-translate-y-1/2 lg:translate-x-0 lg:left-6 lg:right-auto xl:left-10 lg:w-2/5 lg:rounded-2xl
                    z-20 max-h-[80%] flex-col overflow-y-auto
                    shadow-2xl
                    dark:bg-dark-foreground/50 backdrop-blur-md"
             dir="rtl"
             data-home-car-search="{{ position }}">
        </div>
    {% endif %}
    {% endif %}
</section>
