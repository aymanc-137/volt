<!-- Categories Grid -->
{% set slashbg = component.slas_hbg | default(false) %}
{% set marquee = component.marquee | default(false) %}
{% set marqueetext = component.marqueetext | default(" سرعة /// أداء /// تحكم ") %}
{% set enable_border = component.enable_border | default(false) %}
{% set marquee_text_position = component.marquee_text_position | default('both') %}
{% set marquee_is_moving = component.marquee_is_moving %}
{% set marquee_text_size = component.marquee_text_size | default('8') %}
{% set slas_hbg_size = component.slas_hbg_size | default('20') %}
{% set slas_hbg_use_primary_color = component.slas_hbg_use_primary_color %}
{% set slas_hbg_color = component.slas_hbg_color~"1A" | default('#0000001A') %}
{% set slas_hbg_type = component.slas_hbg_type | default('inclined') %}
{% set slas_angle = slas_hbg_type == 'vertical' ? '90' : (slas_hbg_type == 'horizontal' ? '0' : '135') %}
{% set glow_type = component.enable_glow | default('none') %}
{% set glow_use_theme = component.glow_use_theme_colors ?? true %}
{% set glow_c1 = glow_use_theme ? 'var(--color-primary)'  : (component.glow_color_1 ?? 'var(--color-primary)') %}
{% set glow_c2 = glow_use_theme ? 'var(--color-scandary)' : (component.glow_color_2 ?? 'var(--color-scandary)') %}

{# ---- Title controls (inline-applied to preserve this component's layout) ---- #}
{% set tc_size = component.title_size | default(36) %}
{% set tc_size = tc_size > 0 ? tc_size : 36 %}
{% set tc_sub = component.sub_title_size | default(18) %}
{% set tc_sub = tc_sub > 0 ? tc_sub : 18 %}
{% set tc_underline = component.enable_title_underline ?? true %}
{% set tc_font = (component.title_use_decorative_font ?? true) ? 'font-alshohadaa' : '' %}
{% set tc_color_type = component.title_color_type | default('default') %}
{% if tc_color_type == 'primary' %}
    {% set tc_color_style = 'color: var(--color-primary);' %}
{% elseif tc_color_type == 'custom' %}
    {% set tc_color_style = 'color: ' ~ (component.title_color | default('#2C3E50')) ~ ';' %}
{% else %}
    {% set tc_color_style = '' %}
{% endif %}
{% set tc_size_style = 'font-size: clamp(' ~ (tc_size * 0.6)|round ~ 'px, 6vw, ' ~ tc_size ~ 'px);' %}
{% set tc_sub_style = 'font-size: clamp(' ~ (tc_sub * 0.8)|round ~ 'px, 2.5vw, ' ~ tc_sub ~ 'px);' %}
{% set tc_hl_type = component.highlight_word_color_type | default('gradient') %}
{% if tc_hl_type == 'primary' %}
    {% set tc_hl_attr = 'style="color: var(--color-primary)"' %}
{% elseif tc_hl_type == 'custom' %}
    {% set tc_hl_attr = 'style="color: ' ~ (component.highlight_word_color | default('#FF3B3B')) ~ '"' %}
{% else %}
    {% set tc_hl_attr = 'class="bg-gradient-to-r from-primary to-scandary bg-clip-text text-transparent"' %}
{% endif %}

 
<section class="z-10 overflow-hidden {{ enable_border ? 'border-y border-[var(--color-primary)]' : ''}} py-20 relative {{ slashbg ? 'slash-bg-' ~ position ~ ' dynamic-bg-color' : ''}} pb-32">
	{% if glow_type == 'circles' %}
	<div class="absolute top-[15%] left-[25%] w-64 h-64 rounded-full blur-3xl opacity-60 pointer-events-none" style="z-index:-1; background-color:{{ glow_c1 }};"></div>
	<div class="absolute bottom-[15%] right-[25%] w-56 h-56 rounded-full blur-3xl opacity-60 pointer-events-none" style="z-index:-1; background-color:{{ glow_c2 }};"></div>
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-52 h-52 rounded-full blur-3xl opacity-60 pointer-events-none" style="z-index:-1; background-color:{{ glow_c1 }};"></div>
	{% elseif glow_type == 'sides' %}
	<div class="absolute inset-y-0 left-0 pointer-events-none" style="z-index:-1; width:40%; background:linear-gradient(to right, {{ glow_c1 }}, transparent); opacity:0.22;"></div>
	<div class="absolute inset-y-0 right-0 pointer-events-none" style="z-index:-1; width:40%; background:linear-gradient(to left, {{ glow_c2 }}, transparent); opacity:0.22;"></div>
	{% elseif glow_type == 'top_bottom' %}
	<div class="absolute inset-x-0 top-0 pointer-events-none" style="z-index:-1; height:45%; background:linear-gradient(to bottom, {{ glow_c1 }}, transparent); opacity:0.22;"></div>
	<div class="absolute inset-x-0 bottom-0 pointer-events-none" style="z-index:-1; height:45%; background:linear-gradient(to top, {{ glow_c2 }}, transparent); opacity:0.22;"></div>
	{% elseif glow_type == 'left' %}
	<div class="absolute inset-y-0 left-0 pointer-events-none" style="z-index:-1; width:40%; background:linear-gradient(to right, {{ glow_c1 }}, transparent); opacity:0.25;"></div>
	{% elseif glow_type == 'right' %}
	<div class="absolute inset-y-0 right-0 pointer-events-none" style="z-index:-1; width:40%; background:linear-gradient(to left, {{ glow_c1 }}, transparent); opacity:0.25;"></div>
	{% elseif glow_type == 'top' %}
	<div class="absolute inset-x-0 top-0 pointer-events-none" style="z-index:-1; height:45%; background:linear-gradient(to bottom, {{ glow_c1 }}, transparent); opacity:0.25;"></div>
	{% elseif glow_type == 'bottom' %}
	<div class="absolute inset-x-0 bottom-0 pointer-events-none" style="z-index:-1; height:45%; background:linear-gradient(to top, {{ glow_c1 }}, transparent); opacity:0.25;"></div>
	{% endif %}
	{% if marquee %}

	{% if marquee_text_position == 'top' or marquee_text_position == 'both' %}
	<div class="styleish-text absolute top-10 left-0 w-full opacity-10 pointer-events-none select-none overflow-hidden" dir="ltr">
		<div 
		style="font-size: {{marquee_text_size}}rem; line-height:1;"
		class="{{ marquee_is_moving ? 'marquee-reverse-sections' : '' }} flex whitespace-nowrap w-max">
			<span class="font-alshohadaa font-bold display-text whitespace-nowrap px-4 dynamic-text-color">
				{{marqueetext}}&nbsp;&nbsp;&nbsp; {{marqueetext}}&nbsp;&nbsp;&nbsp; {{marqueetext}}&nbsp;&nbsp;&nbsp; {{marqueetext}}
			</span>
			<span class="font-alshohadaa font-bold display-text whitespace-nowrap px-4 dynamic-text-color">
				{{marqueetext}}&nbsp;&nbsp;&nbsp;{{marqueetext}}&nbsp;&nbsp;&nbsp; {{marqueetext}}&nbsp;&nbsp;&nbsp; {{marqueetext}}
			</span>
		</div>
	</div>
	{% endif %}

	{% if marquee_text_position == 'bottom' or marquee_text_position == 'both' %}
	<div class="styleish-text absolute bottom-10 left-0 w-full opacity-10 pointer-events-none select-none overflow-hidden" dir="ltr">
		<div
		style="font-size: {{marquee_text_size}}rem; line-height:1;"
		class="{{ marquee_is_moving ? 'marquee-content-sections' : '' }} flex whitespace-nowrap w-max">
			<span class="font-alshohadaa font-bold display-text whitespace-nowrap px-4 dynamic-text-color">
				{{marqueetext}}&nbsp;&nbsp;&nbsp; {{marqueetext}}&nbsp;&nbsp;&nbsp; {{marqueetext}}&nbsp;&nbsp;&nbsp; {{marqueetext}}
			</span>
			<span class="font-alshohadaa font-bold display-text whitespace-nowrap px-4 dynamic-text-color">
				{{marqueetext}}&nbsp;&nbsp;&nbsp;{{marqueetext}}&nbsp;&nbsp;&nbsp; {{marqueetext}}&nbsp;&nbsp;&nbsp; {{marqueetext}}
			</span>
		</div>
	</div>
	{% endif %}

	{% endif %}

	 
	<div class="container mx-auto px-6">

		<div class="mx-auto">
			{% if component.title %}
				<h2 class="{{ tc_font }} mb-12 text-center italic uppercase dynamic-text-color" style="{{ tc_size_style }} {{ tc_color_style }}">
					{% if component.enable_gradient_word and component.gradient_word %}
						{{ component.title|replace({ (component.gradient_word): '<span ' ~ tc_hl_attr ~ '>' ~ component.gradient_word ~ '</span>' })|raw }}
					{% else %}
						{{ component.title }}
					{% endif %}
				</h2>
				{% if tc_underline %}<span class="navbar-underline mx-auto"></span>{% endif %}
				{% if component.sub_title %}<p class="mx-auto my-5 text-center dynamic-text-color" style="{{ tc_sub_style }}">{{ component.sub_title }}</p>{% endif %}
			{% endif %}
		</div>
		<div class="grid grid-cols-1 md:grid-cols-2 {{ component.categories|length == 3 ? 'lg:grid-cols-3' : 'lg:grid-cols-4' }} gap-4 auto-rows-[22rem] md:auto-rows-fr md:h-[600px]">
			{% for item in component.categories %}
				<!-- Category Card {{ loop.index }} -->
				<div class="relative group -skew-x-3 hover:border-r-8 overflow-hidden h-full border-r-4 border-b border-[var(--color-scandary)] cursor-pointer">
					<a href="{{ item.url }}" class="block h-full w-full">

						<img src="{{ item.image }}" class="absolute inset-0 w-full h-full object-cover transition duration-500 group-hover:scale-110" alt="{{ item.title }}">
						{# <div class="absolute inset-0  opacity-0 group-hover:opacity-40 transition-opacity duration-300"></div> #}
						<div class="absolute inset-0 bg-gradient-to-t from-[var(--color-light-page-background)] dark:from-[var(--color-dark-page-background)] to-transparent duration-300"></div>
						<div class="absolute bottom-0 left-0 p-6 z-10">
							<h3 class="text-3xl font-bold italic uppercase skew-x-[-5deg] dynamic-text-color">{{ item.title }}</h3>
							{# <p class="text-[var(--color-primary)] font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-300">SHOP NOW &rarr;</p> #}
						</div>
					</a>
				</div>
			{% endfor %}
		</div>
	</div>


</section>

<style>

{% if slas_hbg_use_primary_color %}

	.slash-bg-{{position}} 
		{
		background: linear-gradient({{ slas_angle }}deg,var(--color-primary-10) 25%, rgba(0, 0, 0, 0)  
		25%, rgba(0, 0, 0, 0)  50%, var(--color-primary-10)  50%, 
										var(--color-primary-10) 75%, rgba(0, 0, 0, 0) 75%);
										background-size: {{slas_hbg_size}}px {{slas_hbg_size}}px;
		}

{% else %}

	.slash-bg-{{position}} {

	background: linear-gradient({{ slas_angle }}deg,{{slas_hbg_color}} 25%, rgba(0, 0, 0, 0)  
	25%, rgba(0, 0, 0, 0)  50%, {{slas_hbg_color}}  50%, 
									{{slas_hbg_color}} 75%, rgba(0, 0, 0, 0) 75%);
									background-size: {{slas_hbg_size}}px {{slas_hbg_size}}px;
	}

{% endif %}

</style>
