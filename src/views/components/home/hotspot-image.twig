{#
| Variable                          | Type     | Description                                                    |
|-----------------------------------|----------|----------------------------------------------------------------|
| component.title                   | ?string  | Main title                                                     |
| component.sub_title               | ?string  | Subtitle                                                       |
| component.show_title              | bool     | Show the title/subtitle overlay on the image (default true)    |
| component.enable_gradient_title   | bool     | Gradient across full title                                     |
| component.enable_gradient_word    | bool     | Gradient on a single chosen word (if full gradient is off)     |
| component.gradient_word           | ?string  | The word/phrase in the title to color with the gradient        |
| component.image                   | string   | Background image URL                                           |
| component.image_alt               | ?string  | Alt text for the image                                         |
| component.hotspots_json           | string   | JSON array of {x, y, pid, label} from the Hotspot Builder      |
| component.dot_color               | ?string  | Dot fill color (hex)                                           |
| component.dot_accent_color        | ?string  | Pulse / ring color (hex)                                       |
| position                          | int      | Component position in the page                                 |
#}
{% set uid = 'hi-' ~ (position | default(random())) %}
{% set title = component.title | default('') %}
{% set sub_title = component.sub_title | default('') %}
{% set show_title = component.show_title ?? true %}
{% set enable_gradient_title = component.enable_gradient_title ?? false %}
{% set enable_gradient_word = component.enable_gradient_word ?? false %}
{% set gradient_word = component.gradient_word | default('') %}

{# ---- Title controls (inline-applied to preserve this overlay's design; color 'default' keeps the white CSS color) ---- #}
{% set tc_size = component.title_size | default(36) %}
{% set tc_size = tc_size > 0 ? tc_size : 36 %}
{% set tc_sub = component.sub_title_size | default(18) %}
{% set tc_sub = tc_sub > 0 ? tc_sub : 18 %}
{% set tc_underline = component.enable_title_underline ?? true %}
{% set tc_font = (component.title_use_decorative_font ?? true) ? 'font-alshohadaa' : '' %}
{% set tc_color_type = component.title_color_type | default('default') %}
{% if tc_color_type == 'primary' %}
    {% set tc_color_style = 'color: var(--color-primary);' %}
{% elseif tc_color_type == 'custom' %}
    {% set tc_color_style = 'color: ' ~ (component.title_color | default('#2C3E50')) ~ ';' %}
{% else %}
    {% set tc_color_style = '' %}
{% endif %}
{% set tc_size_style = 'font-size: clamp(' ~ (tc_size * 0.6)|round ~ 'px, 6vw, ' ~ tc_size ~ 'px);' %}
{% set tc_sub_style = 'font-size: clamp(' ~ (tc_sub * 0.8)|round ~ 'px, 2.5vw, ' ~ tc_sub ~ 'px);' %}
{% set tc_hl_type = component.highlight_word_color_type | default('gradient') %}
{% if tc_hl_type == 'primary' %}
    {% set tc_hl_attr = 'style="color: var(--color-primary)"' %}
{% elseif tc_hl_type == 'custom' %}
    {% set tc_hl_attr = 'style="color: ' ~ (component.highlight_word_color | default('#FF3B3B')) ~ '"' %}
{% else %}
    {% set tc_hl_attr = 'class="bg-gradient-to-r from-primary to-scandary bg-clip-text text-transparent"' %}
{% endif %}
{% set image = component.image | default('') %}
{% set image_alt = component.image_alt | default(title) %}
{% set hotspots_raw = component.hotspots_json | default('[]') %}
{% set dot_color = component.dot_color ?? '#ffffff' %}
{% set dot_accent = component.dot_accent_color ?? '#a855f7' %}

{% if image %}
<section id="{{ uid }}-section" class="s-block s-block--hotspot-image">

  <style>
    #{{ uid }}-section {
      position: relative;
    }
    #{{ uid }}-stage {
      position: relative;
      width: 100%;
      user-select: none;
      container-type: inline-size;
    }
    #{{ uid }}-stage > img {
      display: block;
      width: 100%;
      height: auto;
      -webkit-user-drag: none;
    }
    #{{ uid }}-stage .hi-title {
      position: absolute;
      top: 0;
      inset-inline: 0;
      z-index: 3;
      padding: clamp(1rem, 3vw, 2rem);
      background: linear-gradient(to bottom, rgba(0,0,0,.55), rgba(0,0,0,0));
      pointer-events: none;
    }
    #{{ uid }}-stage .hi-title h2 {
      margin: 0;
      font-size: clamp(1.1rem, 2.6vw, 2.2rem);
      font-weight: 800;
      line-height: 1.2;
      color: #fff;
    }
    #{{ uid }}-stage .hi-title p {
      margin: .4rem 0 0;
      font-size: clamp(.8rem, 1.5vw, 1.05rem);
      color: rgba(255,255,255,.92);
    }
    #{{ uid }}-stage .hi-title.is-gradient h2 {
      background: linear-gradient(90deg, var(--color-primary), var(--color-scandary));
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent;
    }
    #{{ uid }}-stage .hi-dot {
      /* Scales with the image width so dots shrink on small screens and don't overlap */
      --hi-dot-size: clamp(0.85rem, 4.5cqw, 1.75rem);
      position: absolute;
      width: var(--hi-dot-size);
      height: var(--hi-dot-size);
      margin-left: calc(var(--hi-dot-size) / -2);
      margin-top: calc(var(--hi-dot-size) / -2);
      border-radius: 9999px;
      background: {{ dot_color }};
      border: 2px solid {{ dot_accent }};
      cursor: pointer;
      display: grid;
      place-items: center;
      z-index: 2;
      box-shadow: 0 4px 12px rgba(0,0,0,.3);
      transition: transform .25s ease;
    }
    #{{ uid }}-stage .hi-dot:hover,
    #{{ uid }}-stage .hi-dot.is-active {
      transform: scale(1.2);
    }
    #{{ uid }}-stage .hi-dot::before {
      content: '';
      position: absolute;
      inset: calc(var(--hi-dot-size) * -0.28);
      border-radius: 9999px;
      background: {{ dot_accent }};
      opacity: .5;
      animation: hi-pulse-{{ position }} 2s ease-out infinite;
      z-index: -1;
    }
    #{{ uid }}-stage .hi-dot::after {
      content: '+';
      color: {{ dot_accent }};
      font-weight: 900;
      font-size: calc(var(--hi-dot-size) * 0.62);
      line-height: 1;
    }
    @keyframes hi-pulse-{{ position }} {
      0%   { transform: scale(.8); opacity: .6; }
      100% { transform: scale(1.8); opacity: 0; }
    }

    #{{ uid }}-card {
      position: absolute;
      z-index: 50;
      width: 13.5rem;
      transform: translate(-50%, calc(-100% - 1.5rem));
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity .2s ease, visibility 0s linear .2s;
    }
    #{{ uid }}-card.hi-card-below {
      transform: translate(-50%, 1.5rem);
    }
    #{{ uid }}-card.is-open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition: opacity .2s ease, visibility 0s linear 0s;
    }
    #{{ uid }}-card .hi-loading,
    #{{ uid }}-card .hi-error {
      padding: .75rem;
      background: var(--color-light-page-background, #fff);
      border-radius: .5rem;
      text-align: center;
      font-size: .8rem;
    }
    .dark #{{ uid }}-card .hi-loading,
    .dark #{{ uid }}-card .hi-error { background: var(--color-dark-page-background, #111); color: #fff; }
  </style>

  <div id="{{ uid }}-stage" data-hotspots='{{ hotspots_raw | e('html_attr') }}'>
    <img src="{{ image }}" alt="{{ image_alt | default('') }}" loading="lazy" />

    {# Title overlay inside the image (toggle via show_title) #}
    {% if show_title and (title or sub_title) %}
    <div class="hi-title {{ enable_gradient_title ? 'is-gradient' : '' }}">
      {% if title %}
        {% if enable_gradient_word and gradient_word and not enable_gradient_title %}
          <h2 id="{{ uid }}-title" class="{{ tc_font }}" style="{{ tc_size_style }} {{ tc_color_style }}">{{ title }}</h2>
        {% else %}
          <h2 class="{{ tc_font }}" style="{{ tc_size_style }} {{ tc_color_style }}">{{ title }}</h2>
        {% endif %}
        {% if tc_underline %}<span class="navbar-underline"></span>{% endif %}
      {% endif %}
      {% if sub_title %}<p style="{{ tc_sub_style }}">{{ sub_title }}</p>{% endif %}
    </div>
    {% endif %}

    {# Floating product card overlay — click outside to close #}
    <div id="{{ uid }}-card" role="dialog" aria-hidden="true">
      <div id="{{ uid }}-card-body">
        <div class="hi-loading">
          <salla-loading size="24"></salla-loading>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    function init() {
      var LOG = '[HotspotImage:{{ uid }}]';
      var stage   = document.getElementById('{{ uid }}-stage');
      var card    = document.getElementById('{{ uid }}-card');
      var cardBody = document.getElementById('{{ uid }}-card-body');
      if (!stage || !card) return;
      if (stage.dataset.hiInit === '1') return;
      stage.dataset.hiInit = '1';

      var hotspots = [];
      try {
        hotspots = JSON.parse(stage.dataset.hotspots || '[]');
      } catch (e) {
        console.error(LOG, 'failed to parse hotspots JSON:', e);
        return;
      }
      console.log(LOG, 'hotspots:', hotspots);

      if (!Array.isArray(hotspots) || !hotspots.length) {
        console.warn(LOG, 'no hotspots configured');
        return;
      }

      // Cache product fetches so repeated clicks on the same dot are instant
      var productCache = {};

      hotspots.forEach(function (h, i) {
        if (typeof h.x !== 'number' || typeof h.y !== 'number' || !h.pid) {
          console.warn(LOG, 'skipping invalid hotspot at index', i, h);
          return;
        }
        var dot = document.createElement('button');
        dot.type = 'button';
        dot.className = 'hi-dot';
        dot.style.left = h.x + '%';
        dot.style.top  = h.y + '%';
        dot.setAttribute('aria-label', h.label || ({{ trans('blocks.home.volt.hotspot.product')|json_encode|raw }} + ' ' + (i + 1)));
        dot.dataset.pid = String(h.pid);
        dot.dataset.x = String(h.x);
        dot.dataset.y = String(h.y);
        dot.addEventListener('click', function (ev) {
          ev.stopPropagation();
          openCard(dot);
        });
        stage.insertBefore(dot, card);
      });

      function setActiveDot(dot) {
        stage.querySelectorAll('.hi-dot.is-active').forEach(function (el) {
          el.classList.remove('is-active');
        });
        if (dot) dot.classList.add('is-active');
      }

      function positionCard(dot) {
        var x = parseFloat(dot.dataset.x);
        var y = parseFloat(dot.dataset.y);
        if (isNaN(x) || isNaN(y)) return;
        card.style.left = x + '%';
        card.style.top  = y + '%';
        // If the dot is in the top ~30% of the image, the upward-extending card
        // would clip above the stage. Flip it to render below the dot instead.
        if (y < 30) {
          card.classList.add('hi-card-below');
        } else {
          card.classList.remove('hi-card-below');
        }
      }

      function renderProductCard(product) {
        var card = document.createElement('custom-salla-product-card');
        card.setAttribute('product', JSON.stringify(product));
        card.setAttribute('shadow-on-hover', '');
        return card;
      }

      function openCard(dot) {
        setActiveDot(dot);
        positionCard(dot);
        card.classList.add('is-open');
        card.setAttribute('aria-hidden', 'false');

        var pid = dot.dataset.pid;
        if (productCache[pid]) {
          cardBody.innerHTML = '';
          cardBody.appendChild(renderProductCard(productCache[pid]));
          return;
        }

        cardBody.innerHTML = '<div class="hi-loading"><salla-loading size="32"></salla-loading></div>';

        if (!window.salla || typeof window.salla.product?.fetch !== 'function') {
          cardBody.innerHTML = '<div class="hi-error">' + {{ trans('blocks.home.volt.hotspot.connection_error')|json_encode|raw }} + '</div>';
          return;
        }

        window.salla.product.fetch({
          source: 'selected',
          source_value: [Number(pid)],
        })
          .then(function (res) {
            var products = res?.data?.products || res?.data?.items || res?.data || res?.products || [];
            var product = Array.isArray(products) ? products[0] : products;
            if (!product) {
              cardBody.innerHTML = '<div class="hi-error">' + {{ trans('blocks.home.volt.hotspot.not_found')|json_encode|raw }} + '</div>';
              return;
            }
            productCache[pid] = product;
            cardBody.innerHTML = '';
            cardBody.appendChild(renderProductCard(product));
          })
          .catch(function (err) {
            console.error(LOG, 'product fetch failed', err);
            cardBody.innerHTML = '<div class="hi-error">' + {{ trans('blocks.home.volt.hotspot.load_error')|json_encode|raw }} + '</div>';
          });
      }

      function closeCard() {
        card.classList.remove('is-open');
        card.setAttribute('aria-hidden', 'true');
        setActiveDot(null);
      }

      // Click anywhere outside a dot/card → close
      document.addEventListener('click', function (ev) {
        if (!card.classList.contains('is-open')) return;
        if (card.contains(ev.target)) return;
        if (ev.target.classList && ev.target.classList.contains('hi-dot')) return;
        closeCard();
      });

      // Esc → close
      document.addEventListener('keydown', function (ev) {
        if (ev.key === 'Escape' && card.classList.contains('is-open')) {
          closeCard();
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

{# Wrap the chosen word in a gradient span (same approach as category-list) #}
{% if show_title and enable_gradient_word and gradient_word and not enable_gradient_title %}
<script>
  document.addEventListener('DOMContentLoaded', function () {
    var titleEl = document.getElementById('{{ uid }}-title');
    if (!titleEl) return;
    var word = '{{ gradient_word }}';
    var regex = new RegExp('(' + word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
    titleEl.innerHTML = titleEl.innerHTML.replace(
      regex,
      '<span {{ tc_hl_attr|raw }}>$1</span>'
    );
  });
</script>
{% endif %}
{% endif %}
