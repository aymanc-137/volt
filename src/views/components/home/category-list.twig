{#
| Variable                           | Type     | Description                                                                  |
|------------------------------------|----------|------------------------------------------------------------------------------|
| component                          | object   | Contains merchant settings for fields from twilight.json `component` section |
| component.merge_with_top_component | bool     |                                                                              |
| component.title                    | ?string  | Main title text                                                              |
| component.sub_title                | ?string  | Subtitle/description text                                                    |
| component.enable_gradient_title    | bool     | Enable gradient color for title (primary to secondary color)                 |
| component.enable_gradient_word     | bool     | Enable gradient color for specific word in title                             |
| component.gradient_word            | ?string  | The word to apply gradient color to                                          |
| component.links                    | object[] | list of links                                                                |
| component.links[].icon             | string   |                                                                              |
| component.links[].title            | string   |                                                                              |
| component.links[].url              | string   |                                                                              |
| component.show_car_search          | bool     | Show car-search-tree widget alongside the slider (fetched via JS API)        |
| component.slash_hbg                | bool     | Enable lines background                                                       |
| component.slas_hbg_type            | string   | Line direction: 'inclined' (default) / 'vertical' / 'horizontal'             |
| component.enable_glow              | string   | 'none' / 'circles' / 'sides' / 'top_bottom' / 'left' / 'right' / 'top' / 'bottom' |
| component.glow_use_theme_colors    | bool     | Use theme primary/secondary colors for glow (default true)                   |
| component.glow_color_1             | string   | Custom first glow color (hex) when not using theme colors                    |
| component.glow_color_2             | string   | Custom second glow color (hex) for paired glow types                         |
| component.marquee                  | bool     | Enable marquee text                                                          |
| component.marqueetext              | string   | Marquee text                                                                 |
| position                           | int      | Sorting number start from zero                                               |
#}

{% set slashbg = component.slas_hbg | default(false) %}
{% set show_car_search = component.show_car_search | default(false) %}
{% set marquee = component.marquee | default(false) %}
{% set marqueetext = component.marqueetext | default(" سرعة /// أداء /// تحكم ") %}
{% set enable_border = component.enable_border | default(false) %}
{% set glow_type = component.enable_glow | default('none') %}
{% set glow_use_theme = component.glow_use_theme_colors | default(true) %}
{% set glow_c1 = glow_use_theme ? 'var(--color-primary)'  : (component.glow_color_1 | default('var(--color-primary)')) %}
{% set glow_c2 = glow_use_theme ? 'var(--color-scandary)' : (component.glow_color_2 | default('var(--color-scandary)')) %}
{% set marquee_text_position = component.marquee_text_position | default('both') %}
{% set marquee_is_moving = component.marquee_is_moving %}
{% set marquee_text_size = component.marquee_text_size | default('8') %}
{% set slas_hbg_size = component.slas_hbg_size | default('20') %}
{% set slas_hbg_use_primary_color = component.slas_hbg_use_primary_color %}
{% set slas_hbg_color = component.slas_hbg_color ~ "1A" | default('#0000001A') %}
{% set slas_hbg_type = component.slas_hbg_type | default('inclined') %}
{% set slas_angle = slas_hbg_type == 'vertical' ? '90' : (slas_hbg_type == 'horizontal' ? '0' : '135') %}

{# <span class="navbar-underline"></span> #}
<section
    class="z-10 s-block--categories py-20 relative overflow-hidden pb-32 {{ enable_border ? 'border-y border-[var(--color-primary)]' : '' }} {{ slashbg ? 'slash-bg-' ~ position ~ ' dynamic-bg-color' : '' }}"
>
    {% if marquee %}
        {% if marquee_text_position == 'top' or marquee_text_position == 'both' %}
            <div class="styleish-text absolute top-10 left-0 w-full opacity-10 pointer-events-none select-none overflow-hidden" dir="ltr">
                <div
                    style="font-size: {{ marquee_text_size }}rem; line-height: 1;"
                    class="{{ marquee_is_moving ? 'marquee-reverse-sections' : '' }} flex whitespace-nowrap w-max"
                >
                    <span class="font-alshohadaa font-bold display-text whitespace-nowrap px-4">
                        {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}
                    </span>
                    <span class="font-alshohadaa font-bold display-text whitespace-nowrap px-4">
                        {{ marqueetext }}&nbsp;&nbsp;&nbsp;{{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}
                    </span>
                </div>
            </div>
        {% endif %}

        {% if marquee_text_position == 'bottom' or marquee_text_position == 'both' %}
            <div class="styleish-text absolute bottom-10 left-0 w-full opacity-10 pointer-events-none select-none overflow-hidden" dir="ltr">
                <div
                    style="font-size: {{ marquee_text_size }}rem; line-height: 1;"
                    class="{{ marquee_is_moving ? 'marquee-content-sections' : '' }} flex whitespace-nowrap w-max"
                >
                    <span class="font-alshohadaa font-bold display-text whitespace-nowrap px-4">
                        {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}
                    </span>
                    <span class="font-alshohadaa font-bold display-text whitespace-nowrap px-4">
                        {{ marqueetext }}&nbsp;&nbsp;&nbsp;{{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}&nbsp;&nbsp;&nbsp; {{ marqueetext }}
                    </span>
                </div>
            </div>
        {% endif %}
    {% endif %}

    <!-- Decorative Top Heading -->
    {% if component.title %}
        <div class="mx-auto flex flex-col space-y-6 justify-center items-center my-12 w-5/6">
            <div class="flex flex-col items-center">
                {% if component.enable_gradient_title %}
                    <h1 class="z-1 text-4xl font-alshohadaa mb-5 bg-gradient-to-r from-primary to-scandary bg-clip-text text-transparent">{{ component.title }}</h1>
                {% elseif component.enable_gradient_word and component.gradient_word %}
                    <h1 id="category-list-title-{{ position }}" class="text-4xl z-1 font-alshohadaa mb-5 dynamic-text-color">{{ component.title }}</h1>
                {% else %}
                    <h1 class="z-1 text-4xl font-alshohadaa mb-5 dynamic-text-color">{{ component.title }}</h1>
                {% endif %}
                <span class="navbar-underline"></span>
            </div>

            <div class="z-1 text-center mx-auto text-base lg:text-lg dynamic-text-color">
                {{ component.sub_title }}
            </div>
        </div>

        {% if component.enable_gradient_word and component.gradient_word %}
            <script>
                document.addEventListener('DOMContentLoaded', function () {
                    const titleEl = document.getElementById('category-list-title-{{ position }}');
                    if (titleEl) {
                        const word = '{{ component.gradient_word }}';
                        const regex = new RegExp('(' + word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
                        titleEl.innerHTML = titleEl.innerHTML.replace(
                            regex,
                            '<span class="bg-gradient-to-r from-primary to-scandary bg-clip-text text-transparent">$1</span>'
                        );
                    }
                });
            </script>
        {% endif %}
    {% endif %}

    <div class="container {{ show_car_search ? 'flex flex-col lg:flex-row gap-6 items-start' : '' }}">

        {# Car-search-tree box — JS fills this via salla.api after page load #}
        {% if show_car_search %}
        <div class="lg:w-80 xl:w-96 shrink-0 self-stretch">
            <div data-cat-list-car-search="{{ position }}"
                 class="hidden h-full rounded-xl overflow-hidden border border-[var(--color-primary)] shadow-light bg-light-foreground dark:bg-dark-foreground">
            </div>
        </div>
        {% endif %}

        <div class="flex-1 min-w-0 w-full big-image-category justify-center items-center">
            <salla-slider
                type="carousel"
                controls-outer
                autoplay
                show-controls="true"
                id="main-links-{{ position }}"
            >
                <div slot="items">
                    {% for index, item in component.links %}
                        <div class="swiper-slide my-10 slide-one-one">
                            <div class="w-32 h-32 md:w-56 md:h-56 overflow-hidden category-card category-card-bg-{{ index }}">
                                <h3 class="z-1 text-center my-2 category-name text-lg md:text-2xl font-extrabold place-self-center">{{ item.text }}</h3>

                                <style>
                                    .category-card-bg-{{ index }}:hover {
                                        background: linear-gradient(to bottom, {{ item.color }}4D, {{ item.color }}66);
                                    }
                                </style>

                                <a href="{{ item.url }}" class="w-full h-full flex flex-col items-center justify-evenly">
                                    <img
                                        class="w-32 h-32 bg-contain bg-center border-none bg-no-repeat"
                                        src="{{ item.image }}"
                                    >
                                </a>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </salla-slider>
        </div>

    </div>

    {% if glow_type == 'circles' %}
        <div class="absolute top-[15%] left-[25%] w-64 h-64 rounded-full blur-3xl opacity-60 pointer-events-none" style="z-index:-1; background-color:{{ glow_c1 }};"></div>
        <div class="absolute bottom-[15%] right-[25%] w-56 h-56 rounded-full blur-3xl opacity-60 pointer-events-none" style="z-index:-1; background-color:{{ glow_c2 }};"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-52 h-52 rounded-full blur-3xl opacity-60 pointer-events-none" style="z-index:-1; background-color:{{ glow_c1 }};"></div>
    {% elseif glow_type == 'sides' %}
        <div class="absolute inset-y-0 left-0 pointer-events-none" style="z-index:-1; width:40%; background:linear-gradient(to right, {{ glow_c1 }}, transparent); opacity:0.22;"></div>
        <div class="absolute inset-y-0 right-0 pointer-events-none" style="z-index:-1; width:40%; background:linear-gradient(to left, {{ glow_c2 }}, transparent); opacity:0.22;"></div>
    {% elseif glow_type == 'top_bottom' %}
        <div class="absolute inset-x-0 top-0 pointer-events-none" style="z-index:-1; height:45%; background:linear-gradient(to bottom, {{ glow_c1 }}, transparent); opacity:0.22;"></div>
        <div class="absolute inset-x-0 bottom-0 pointer-events-none" style="z-index:-1; height:45%; background:linear-gradient(to top, {{ glow_c2 }}, transparent); opacity:0.22;"></div>
    {% elseif glow_type == 'left' %}
        <div class="absolute inset-y-0 left-0 pointer-events-none" style="z-index:-1; width:40%; background:linear-gradient(to right, {{ glow_c1 }}, transparent); opacity:0.25;"></div>
    {% elseif glow_type == 'right' %}
        <div class="absolute inset-y-0 right-0 pointer-events-none" style="z-index:-1; width:40%; background:linear-gradient(to left, {{ glow_c1 }}, transparent); opacity:0.25;"></div>
    {% elseif glow_type == 'top' %}
        <div class="absolute inset-x-0 top-0 pointer-events-none" style="z-index:-1; height:45%; background:linear-gradient(to bottom, {{ glow_c1 }}, transparent); opacity:0.25;"></div>
    {% elseif glow_type == 'bottom' %}
        <div class="absolute inset-x-0 bottom-0 pointer-events-none" style="z-index:-1; height:45%; background:linear-gradient(to top, {{ glow_c1 }}, transparent); opacity:0.25;"></div>
    {% endif %}
</section>

<style>
    {% if slas_hbg_use_primary_color %}
        .slash-bg-{{ position }} {
            background: linear-gradient(
                {{ slas_angle }}deg,
                var(--color-primary-10) 25%,
                rgba(0, 0, 0, 0) 25%,
                rgba(0, 0, 0, 0) 50%,
                var(--color-primary-10) 50%,
                var(--color-primary-10) 75%,
                rgba(0, 0, 0, 0) 75%
            );
            background-size: {{ slas_hbg_size }}px {{ slas_hbg_size }}px;
        }
    {% else %}
        .slash-bg-{{ position }} {
            background: linear-gradient(
                {{ slas_angle }}deg,
                {{ slas_hbg_color }} 25%,
                rgba(0, 0, 0, 0) 25%,
                rgba(0, 0, 0, 0) 50%,
                {{ slas_hbg_color }} 50%,
                {{ slas_hbg_color }} 75%,
                rgba(0, 0, 0, 0) 75%
            );
            background-size: {{ slas_hbg_size }}px {{ slas_hbg_size }}px;
        }
    {% endif %}
</style>
