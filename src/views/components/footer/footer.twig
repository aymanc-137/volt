{% set bg_text_enabled = theme.settings.get('footer_bg_text_enabled') ?? true %}
{% set bg_text = theme.settings.get('footer_bg_text') | default('') %}
{% set bg_use_theme = theme.settings.get('footer_bg_text_use_theme_colors') ?? true %}
{% set bg_stroke = bg_use_theme ? 'var(--color-primary)'  : (theme.settings.get('footer_bg_text_stroke_color') ?? 'var(--color-primary)') %}
{% set bg_fill   = bg_use_theme ? 'var(--color-scandary)' : (theme.settings.get('footer_bg_text_fill_color')   ?? 'transparent') %}

{# ---- Footer line-pattern background (same configuration as home.category-list) ---- #}
{% set footer_slashbg = theme.settings.get('footer_slash_bg') ?? true %}
{% set footer_slas_size = theme.settings.get('footer_slash_bg_size') | default('20') %}
{% set footer_slas_use_primary = theme.settings.get('footer_slash_bg_use_primary_color') ?? true %}
{% set footer_slas_color = (theme.settings.get('footer_slash_bg_color') | default('#000000')) ~ '1A' %}
{% set footer_slas_type = theme.settings.get('footer_slash_bg_type') | default('inclined') %}
{% set footer_slas_angle = footer_slas_type == 'vertical' ? '90' : (footer_slas_type == 'horizontal' ? '0' : '135') %}

{# ---- Footer email-list (newsletter) column — posts email to a merchant URL ---- #}
{% set email_list_enabled = theme.settings.get('footer_email_list_enabled') ?? false %}
{% set email_list_url = theme.settings.get('footer_email_list_url') | default('') %}
{% set email_list_active = email_list_enabled and email_list_url %}
{% set email_list_title = theme.settings.get('footer_email_list_title') | default('النشرة البريدية') %}
{% set email_list_desc = theme.settings.get('footer_email_list_desc') | default('') %}
{% set email_list_placeholder = theme.settings.get('footer_email_list_placeholder') | default('أدخل بريدك الإلكتروني') %}
{% set email_list_button = theme.settings.get('footer_email_list_button') | default('اشتراك') %}

{# ---- Store-app icons position: under the logo/social box, next to the email bar, or a separate column ---- #}
{% set apps_pos = theme.settings.get('footer_apps_position') | default('under') %}
{# 'email' position only applies when the email bar is shown; otherwise fall back to 'under' #}
{% if apps_pos == 'email' and not email_list_active %}{% set apps_pos = 'under' %}{% endif %}

<style>
  .store-footer__bg-text-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    user-select: none;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 0;
  }
  .store-footer__bg-text {
    font-family: 'alshohadaa', var(--font-family, sans-serif);
    font-weight: 900;
    font-size: clamp(8rem, 22vw, 22rem);
    line-height: .85;
    letter-spacing: -.02em;
    white-space: nowrap;
    margin: 0;
    background: linear-gradient(to bottom, {{ bg_stroke }} 50%, {{ bg_fill }} 50%);
    -webkit-background-clip: text;
            background-clip: text;
    -webkit-text-fill-color: transparent;
            color: transparent;
    opacity: .9;
  }
  .store-footer__inner { position: relative; padding-top: 3rem; }
  .store-footer__inner > .container,
  .store-footer__bottom { position: relative; z-index: 2; }
  {% if footer_slashbg %}
  .footer-slash-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      {{ footer_slas_angle }}deg,
      {{ footer_slas_use_primary ? 'var(--color-primary-10)' : footer_slas_color }} 25%,
      rgba(0, 0, 0, 0) 25%,
      rgba(0, 0, 0, 0) 50%,
      {{ footer_slas_use_primary ? 'var(--color-primary-10)' : footer_slas_color }} 50%,
      {{ footer_slas_use_primary ? 'var(--color-primary-10)' : footer_slas_color }} 75%,
      rgba(0, 0, 0, 0) 75%
    );
    background-size: {{ footer_slas_size }}px {{ footer_slas_size }}px;
  }
  {% endif %}
</style>

<footer class="store-footer ">
	<div aria-label="footer" class="store-footer__inner !pb-0 ">
	{% if bg_text_enabled and bg_text %}
		<div class="store-footer__bg-text-wrap" aria-hidden="true">
			<span class="store-footer__bg-text">{{ bg_text }}</span>
		</div>
	{% endif %}
	{% if footer_slashbg %}
		<div class="footer-slash-bg" aria-hidden="true"></div>
	{% endif %}

	{# Email subscription bar — top of the footer #}
	{% if email_list_active %}
		<div class="footer-email-top w-full  ">
			<div class="  mx-auto    dynamic-bg-color-40
       backdrop-blur-sm border dynamic-border-color
       dynamic-text-color   ">

       <div class="p-4 flex flex-col md:flex-row md:items-center md:justify-between gap-4 container">
               <div class="flex-1">

				<span class="color-primary font-alshohadaa">{{ email_list_title }}</span>
				{% if email_list_desc %}
					<p class="text-sm     ">{{ email_list_desc }}</p>
				{% endif %}
				<form action="{{ email_list_url }}" method="get" target="_blank" rel="noopener" class="flex flex-row items-stretch gap-2 mt-3">
					<input type="email" name="email" required
						placeholder="{{ email_list_placeholder|e('html_attr') }}"
						aria-label="{{ email_list_placeholder|e('html_attr') }}"
						class="form-input min-w-0 {{ apps_pos == 'email' ? '' : 'md:!w-2/5' }} dynamic-bg-color dynamic-border-color rounded-custom">
					<button type="submit" class="btn btn--primary !flex-none !px-5 whitespace-nowrap">{{ email_list_button }}</button>
				</form>
</div>
        {% if apps_pos == 'email' %}
        <div class="flex-1 flex flex-col items-center justify-center gap-2">
           <salla-apps-icons class="block"></salla-apps-icons>
        </div>
        {% endif %}


        </div>
			</div>
		</div>
	{% endif %}

	<hr class="w-full border-t dynamic-border-color " >
		<div class="container dynamic-bg-color-40
     backdrop-blur-sm border-x
        dynamic-border-color
         grid grid-col-1 {{ apps_pos == 'column' ? 'lg:grid-cols-5' : 'lg:grid-cols-4' }} gap-0">
			<div class="lg:col-span-2 
   
					border-l
					dynamic-border-color
					dynamic-text-color
					flex flex-col items-center text-center" >
				<a href="{{ link('/') }}" class="flex flex-col items-center m-0" aria-label="{{ store.name }} logo">
					{% if store.logo %}
						<img src="{{ store.logo }}" alt="{{ store.name }} logo" width="80" height="80" loading="lazy" class="max-h-20 w-auto object-contain" />
					{% endif %}
					<h3 class="m-0 text-center">{{ store.name }}</h3>
				</a>
				{% if store.description %}
					<div class="max-w-sm leading-6 mb-6">
						{{ store.description|raw }}
        			  </div>
				{% endif %}

				<div class="hidden lg:block">
					<salla-social class="block mb-6"></salla-social>
				</div>

				{% if apps_pos == 'under' %}
					<salla-apps-icons class="block mt-4"></salla-apps-icons>
				{% endif %}

          {# trust badges #}
          <salla-trust-badges {% if theme.settings.get('footer_is_dark') %} dark {% endif %}></salla-trust-badges>

          {# vat #}
          {% if store.settings.tax.number %}
            <div class="flex rtl:space-x-reverse space-x-2 items-end justify-center">
              {% if store.settings.tax.certificate %}
                <a class="load-img-onclick" data-modal-id="modal-value-tax" href="#/" alt="{{ store.settings.tax.number }}">
     <img width="40" height="50" src="{{'images/tax.png' | cdn(70,70)}}" loading="lazy" class="w-10 rounded-sm hover:opacity-80 transition-opacity" alt="value added tax">                </a>
              {% endif %}
              <div>
                <p class="text-sm text-text-grey mb-1">{{ trans('common.elements.tax_number') }}</p>
                <b class="text-sm">{{ store.settings.tax.number }}</b>
              </div>
            </div>

            {% if store.settings.tax.certificate %}
              <salla-modal sub-title-first sub-title="{{ trans('common.elements.tax_number') }}" modal-title="{{ store.settings.tax.number }}" id="modal-value-tax">
                <div class="flex justify-center max-w-full">
                  <img class="w-full" loading="lazy" 
                                  src="{{ store.settings.tax.certificate }}" 
                  alt="{{ store.settings.tax.number }}"/>
                </div>
              </salla-modal>
            {% endif %}
          {% endif %}
        </div>

			<div class="border-l border-r 
			dynamic-border-color
			dynamic-text-color
			p-8">
				<h3>{{ trans('blocks.footer.pages_links') }}</h3>

        <salla-menu source="footer" with-cookie-preferences></salla-menu>
			</div>

			<div class="border-l border-r
			dynamic-border-color
			dynamic-text-color
			 p-8">
				<salla-contacts></salla-contacts>

				<div class="lg:hidden contact-social">
					<salla-social></salla-social>
				</div>
			</div>

			{% if apps_pos == 'column' %}
			<div class="border-l border-r
			dynamic-border-color
			dynamic-text-color
			 p-8">
 				<salla-apps-icons vertical class="block mt-4"></salla-apps-icons>
			</div>
			{% endif %}

		</div>
 
	</div>

	<div class="store-footer__bottom md:flex items-center justify-between py-4 dynamic-text-color container text-center">
		<span class="text-sm copyright-text">{% hook copyright %}</span>
		<salla-payments></salla-payments>
	</div>
</div>

<span class="hidden bottom-2 rtl:pl-24 ltr:pr-24 md:grid-cols-3 opacity-40"></span></footer>
