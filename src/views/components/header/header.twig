{#
| Variable         | Type    | Description                     |
|------------------|---------|---------------------------------|
| cart             | object  |                                 |
| cart.items_count | int     |                                 |
| cart.total       | string  | Formatted total ex: "١٠٠ ر.س"   |
#}
{% set important_links = theme.settings.get('important_links') %}
{% set show_topnav = theme.settings.get('show_topnav', true) %}
<header class="store-header ">
  {# Top Nav #}
  {% if show_topnav %}
  <div  class="top-navbar  bg-light-background dark:bg-dark-background  dynamic-text-color">
    <div class="container flex justify-between">
      <div class="flex-1 flex items-center gap-2">
          {# Footer Menu #}
          {% if important_links %}
            <salla-menu source="footer" topnav></salla-menu>
          {% endif %}

          {# Language & Currency Component #}
          <div class="header-buttons">
              {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
                   <salla-localization-modal show-trigger></salla-localization-modal>
              {% endif %}
          </div>

          {# Scopes | Branches #}
          {% if store.scope %}
              <button class="btn--rounded-gray"
                      onclick="salla.event.dispatch('scopes::open', {'mode': 'default'})">
                  <i class="sicon-location rtl:ml-1 ltr:mr-1"></i> {{ store.scope.name }}
              </button>
          {% endif %}

          {# Search bar #}
          <div class="header-search flex-1">
            <salla-search inline height="36"></salla-search>
          </div>
      </div>

      <salla-contacts is-header></salla-contacts>
    </div>
  </div>
  {% endif %}

  {# Main Nav #}
  <div id="mainnav" class="main-nav-container   dynamic-bg-color !font-thin shadow-default ">
      <div class="inner   bg-inherit">
          <div class=" mx-10 header-content">
              {% set header_layout = theme.settings.get('header_layout', 'centered_menu') %}
              {% set is_drawer_layout = header_layout == 'centered_logo_drawer' %}
              <div class="flex items-stretch justify-between relative {{ is_drawer_layout ? 'min-h-[68px] lg:min-h-[84px]' : '' }}">
                  <div class="flex items-center">
                      {% if is_drawer_layout %}
                        {# Layout 3: our custom drawer menu replaces the native mobile menu at all widths #}
                        <volt-drawer-menu></volt-drawer-menu>
                      {% else %}
                        {# Layouts 1 & 2: native hamburger handles mobile, horizontal menu shows on desktop #}
                        <a class="lg:hidden mburger mburger--collapse leading-none rtl:ml-4 ltr:mr-4" href="#mobile-menu" aria-label="Open-menu">
                          <i class="hover:text-[var(--color-primary)] sicon-menu text-primary text-2xl"></i>
                        </a>
                      {% endif %}

                      {# Logo — inline at the start for the horizontal-menu layouts #}
                      {% if not is_drawer_layout %}
                        <a class="navbar-brand" href="{{ store.url }}">
                            <img fetchpriority="high" width="100%" height="100%" loading="eager" src="{{ store.logo }}" alt="{{ store.name }} logo">
                            {% if is_page('index') %}
                              <h1 class="sr-only">{{ store.name }}</h1>
                            {% else %}
                              <h2 class="sr-only">{{ store.name }}</h2>
                            {% endif %}
                        </a>
                      {% endif %}

                      {# Layout 2: horizontal menu sits right next to the logo #}
                      {% if header_layout == 'menu_beside_logo' %}
                        <custom-main-menu></custom-main-menu>
                      {% endif %}
                  </div>

                  {# Layout 1 (default): horizontal menu centered between logo and icons #}
                  {% if header_layout == 'centered_menu' %}
                    <custom-main-menu></custom-main-menu>
                  {% endif %}

                  {# Layout 3: logo absolutely centered in the bar #}
                  {% if is_drawer_layout %}
                    <a class="navbar-brand absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" href="{{ store.url }}">
                        <img fetchpriority="high" width="100%" height="100%" loading="eager" src="{{ store.logo }}" alt="{{ store.name }} logo">
                        {% if is_page('index') %}
                          <h1 class="sr-only">{{ store.name }}</h1>
                        {% else %}
                          <h2 class="sr-only">{{ store.name }}</h2>
                        {% endif %}
                    </a>
                  {% endif %}

                  <div class="flex items-center justify-end">


                  {% if user.type=='user' %}
                      <salla-user-menu avatar-only show-header show-trigger></salla-user-menu>
                      {% else %}
                          <button class="header-btn mr-[9px] rtl:ml-[9px] rtl:mr-[unset] dynamic-text-color" aria-label="user-icon" onclick="salla.event.dispatch('login::open')">
                            <i class="header-btn__icon sicon-user-circle hover:text-[var(--color-primary)] dynamic-text-color"></i>
                          </button>
                      {% endif %}
              {% if theme.settings.get('dark_mode_enabled', true) %}
                      <button
                        id="theme-toggle"
                        class="header-btn   "
                        type="button"
                        aria-pressed="false"
                        aria-label="Toggle color mode"
                      >
                        <i class="hover:text-[var(--color-primary)] header-btn__icon icon sicon-moon hidden dynamic-text-color" data-theme-icon="dark" aria-hidden="true" style="display:none"></i>

                        <i class="hover:text-[var(--color-primary)] header-btn__icon icon sicon-sun dynamic-text-color" data-theme-icon="light" aria-hidden="true"></i>
                        <span class="sr-only">Toggle color mode</span>
                      </button>
                      {% endif %}


                            <button class="   dynamic-text-color" 
                              id="search-btn"
                              type="button"
                              data-modal-id="search-modal-volt"
                              aria-label="user-icon" 
                              onclick="(function(){event.preventDefault();
                                document.querySelector('#search-modal-volt').open();
                                return false;})();">
                            <i class="hover:text-[var(--color-primary)] header-btn__icon sicon-search dynamic-text-color"></i>
                          </button>


                    <salla-cart-summary class="ml-4 rtl:ml-[unset] rtl:mr-4 dynamic-text-color">
                      {#  #}
                        <i slot="icon" class=" hover:text-[var(--color-primary)] header-btn__icon icon sicon-shopping-bag dynamic-text-color"></i>
                      </salla-cart-summary>


                  </div>
              </div>
          </div>
      </div>
  </div>
  <span class="navbar-underline"></span>
</header>


  <salla-modal has-skeleton="true" position="top" class="custom-salla-volt-modal" id="search-modal-volt">
    <h4>{{ trans('blocks.footer.search') }}</h4>
		<hr>
      <div class="m-3 flex-1 md:h-10 h-96">
        <salla-search inline height="36"></salla-search>
    </div>
   </salla-modal>