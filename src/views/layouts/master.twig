{# ############## Shared Variables in all views ################
| Variable                                           | Type     | Description                                                                                              |
|----------------------------------------------------|----------|----------------------------------------------------------------------------------------------------------|
| store                                              | Store    |                                                                                                          |
| store.id                                           | int      |                                                                                                          |
| store.name                                         | string   |                                                                                                          |
| store.username                                     | string   |                                                                                                          |
| store.description                                  | string   |                                                                                                          |
| store.slogan                                       | ?string  | * if feature in twilight.json                                                                            |
| store.logo                                         | string   |                                                                                                          |
| store.url                                          | string   |                                                                                                          |
| store.api                                          | string   | the api url for current store                                                                            |
| store.icon                                         | string   | *fav icon url                                                                                            |
| store.contacts                                     | object   | [mobile, phone, email, whatsapp, telegram], ex. store.contacts.email                                     |
| store.social                                       | object   | [instagram, snapchat, twitter, youtube, facebook, pinterest, maroof, whatsapp], ex. store.social.twitter |
| store.settings                                     | object   |                                                                                                          |
| store.settings.auth.email_allowed                  | bool     |                                                                                                          |
| store.settings.auth.mobile_allowed                 | bool     |                                                                                                          |
| store.settings.auth.is_email_required              | bool     |                                                                                                          |
| store.settings.cart.apply_coupon_enabled           | bool     | Does visitor allowed to applay coupon in cart page                                                       |
| store.settings.product.total_sold_enabled          | bool     |                                                                                                          |
| store.settings.product.fit_type                    | ?string  | null when equal product card size is off, or ['cover', 'contain']                                        |
| store.settings.category.testimonial_enabled        | bool     | Show random testimonials in category page                                                                |
| store.settings.tax.number                          | ?string  |                                                                                                          |
| store.settings.tax.certificate                     | ?string  | certificate image url                                                                                    |
| store.settings.tax.taxable_prices_enabled          | bool     | Does tax included in the prices ex product_price 100 & tax is 15, price will be 115                      |
| store.settings.rating_enabled                      | bool     | Is one of: store_enabled or shipping_enabled or products_enabled                                         |
| store.settings.arabic_numbers_enabled              | bool     | Does the merchant wants the numbers to be shown as Arabic format                                         |
| store.settings.is_multilingual                     | bool     |                                                                                                          |
| store.settings.currencies_enabled                  | bool     |     
| theme                                              | Theme    |                                                                                                          |
| theme.id                                           | int      |                                                                                                          |
| theme.name                                         | string   |                                                                                                          |
| theme.mode                                         | string   | `live`, `preview`                                                                                        |
| theme.is_rtl                                       | bool     |                                                                                                          |
| theme.translations_hash                            | int      | to be used in case merchant updated frontend store translations                                          |
| theme.color                                        | object   |                                                                                                          |
| theme.color.primary                                | string   |                                                                                                          |
| theme.color.text                                   | string   | suitable text color comparing to `theme.primary.color`, #000000, #FFFFFF                                 |
| theme.color.reverse_primary                        | string   |                                                                                                          |
| theme.color.reverse_text                           | string   | if `theme.text_color=#000000` means that `theme.reverse_text_color=#FFFFFF`                              |
| theme.color.is_dark                                | bool     | Does main store color `theme.primary.color` considered as dim color?                                     |
| theme.color.darker(float alpha, ?string hexColor)  | string   | get darker color from `theme.primary.color` or from passed color, `alpha` range from 0.0-1.0             |
| theme.color.lighter(float alpha, ?string hexColor) | string   | get lighter color from `theme.primary.color` or from passed color, `alpha` range from 0.0-1.0            |
| theme.font                                         | ?object  | Salla predefined font, null when the theme doesn't have `fonts` feature                                  |
| theme.font.name                                    | string   | DINNextLTArabic-Regular, Amazon-Ember, Apple, Dubai, Estedad                                             |
| theme.font.url                                     | string   | css full url ex: 'https://my_store.test/dist/fonts/default.css'                                          |
| theme.settings                                     | object   | dynamic object with values of the `settings` in twilight.json ex. `theme.settings.topnav_is_dark`        |
| theme.settings.set(settingName, value)             | string   | set global var, then get it {{theme.settings.get('my_var','fallback') }}                                 |
| theme.settings.get(settingName, default=null)      | mixed    | get theme setting ex `theme.settings.get('my_var', 'fallback')`                                          |
#}
<!DOCTYPE html>
<html lang="{{ user.language.code }}" dir="{{ user.language.dir }}"

style=" overflow-y: scroll;"
>
<!-- بسم الله الرحمن الرحيم -->
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {{ theme.settings.set('placeholder', 'images/placeholder.png') }}

    {% include 'pages.partials.loading-screen-assets' %}

    <script defer data-cfasync="false" src="{{ 'product-card.js'|asset }}"></script>
    <script defer src="{{ 'main-menu.js'|asset }}"></script>

    {% block head_scripts %}{% endblock %}


    <script data-cfasync="false">
        window.header_is_sticky = "{{theme.settings.get('header_is_sticky', 'Default Value')}}"
        window.imageZoom = "{{theme.settings.get('imageZoom')}}"
        window.can_access_wallet = {{ user.can_access_wallet | json_encode }}
    </script>
    
    {% hook 'head:start' %}
    {% hook head %}
    {% block styles %}{% endblock %}
    <link rel="stylesheet" href="{{ 'app.css' | asset }}">
    <link rel="stylesheet" href="{{ theme.font.path|cdn }}"/>
    <link rel="stylesheet" href="{{ 'fonts/sallaicons.css'|cdn }}"/>
    
    <style>
        :root {
            --font-main: '{{theme.font.name}}';
            --color-primary: {{ theme.color.primary }};

            --color-primary-5: {{ theme.color.primary }}0D;
            --color-primary-10: {{ theme.color.primary }}1A;


            --color-primary-20: {{ theme.color.primary }}40;
            --color-primary-30: {{ theme.color.primary }}4D;


            --color-primary-40: {{ theme.color.primary }}73;
            --color-primary-50: {{ theme.color.primary }}80;

            --color-primary-dark: {{ theme.color.darker(0.15) }};
            --color-primary-light: {{ theme.color.lighter(0.15) }};
            --color-primary-reverse: {{ theme.settings.get('color_primary_reverse', theme.color.reverse_text) }};
            --color-scandary: {{ theme.settings.get('color_scandary', '#FF3B3B') }};
            --color-scandary-trans: {{ theme.settings.get('color_scandary', '#FF3B3B') }}40;

            --color-light-page-background: {{ theme.settings.get('color_light_page_background', '#F9F7F6') }};
            --color-light-box-background: {{ theme.settings.get('color_light_box_background', '#f1f1f1') }};
            
            --color-dark-page-background: {{ theme.settings.get('color_dark_page_background', '#262626') }};
            --color-dark-box-background: {{ theme.settings.get('color_dark_box_background', '#171717') }};

             --color-light-page-background-40: {{ theme.settings.get('color_light_page_background', '#F9F7F6') }}80;
            --color-light-box-background-40: {{ theme.settings.get('color_light_box_background', '#f1f1f1') }}80;

            --color-dark-page-background-40: {{ theme.settings.get('color_dark_page_background', '#262626') }}80;
            --color-dark-box-background-40: {{ theme.settings.get('color_dark_box_background', '#171717') }}80;

      

            --light-text-color: {{ theme.settings.get('light-text-color', '#e5e7eb') }};
            --main-text-color: {{ theme.settings.get('main-text-color', '#2C3E50') }};
           
            --color-border:{{theme.settings.get('color_border', '#2C3E50')}};
            --color-border-dark:{{theme.settings.get('color_border_dark', '#2C3E50')}};

            







            --border-radius: {{ theme.settings.get('border_radius', '0.375rem') }};

            /* --shadow-glow: 0 0 20px hsl(0 84% 55% / 1); */
            --shadow-glow-lg: 0 0 30px  {{theme.color.primary}};
            --shadow-glow-md: 0 0 25px  {{theme.color.primary}};
            --shadow-glow-sm: 0 0 15px {{theme.color.primary}};
            --shadow-glow: 0 0 20px  {{theme.color.primary}};


        }

.main-bg-testing {
    background-image: linear-gradient(145deg,#000000, #00123A, #023061 , #00123A ,#000000 );
    background-size: 100% 100%;
    background-attachment: fixed;    /* KEY: fixes background to viewport */
    background-position: center;
    background-repeat: no-repeat;
}
    </style>
    <script>
        (function () {
            var STORAGE_KEY = 'theme-mode';
            var root = document.documentElement;
            var darkModeEnabled = {{ theme.settings.get('dark_mode_enabled', true) ? 'true' : 'false' }};

            function persistMode(mode) {
                try {
                    localStorage.setItem(STORAGE_KEY, mode);
                } catch (error) {
                    // Silently fail when storage is unavailable.
                }
            }

            function dispatchThemeChange(mode) {
                try {
                    window.dispatchEvent(new CustomEvent('theme:change', { detail: { mode: mode } }));
                } catch (error) {
                    // Ignore environments that block custom events.
                }
            }

            function toggleRootClass(isDark) {
                if (isDark) {
                    root.classList.add('dark');
                    return true;
                }

                root.classList.remove('dark');
                return false;
            }

            function applyMode(mode, shouldPersist) {
                // Force light mode if dark mode is disabled
                if (!darkModeEnabled) {
                    toggleRootClass(false);
                    persistMode('light');
                    dispatchThemeChange('light');
                    return false;
                }

                var isDark = toggleRootClass(mode === 'dark');
                if (shouldPersist) {
                    persistMode(isDark ? 'dark' : 'light');
                }
                dispatchThemeChange(isDark ? 'dark' : 'light');
                return isDark;
            }

            function readStoredMode() {
                try {
                    return localStorage.getItem(STORAGE_KEY);
                } catch (error) {
                    return null;
                }
            }

            // Force light mode if dark mode is disabled, otherwise use stored or default to light
            applyMode(darkModeEnabled ? (readStoredMode() || 'light') : 'light', false);

            document.addEventListener('DOMContentLoaded', function () {
                var toggle = document.getElementById('theme-toggle');

                if (!toggle) {
                    return;
                }

                var lightIcon = toggle.querySelector('[data-theme-icon="light"]');
                var darkIcon = toggle.querySelector('[data-theme-icon="dark"]');

                var updateToggleState = function (isDark) {
                    toggle.setAttribute('aria-pressed', String(isDark));
                    if (lightIcon) {
                        lightIcon.classList.toggle('hidden', isDark);
                        lightIcon.style.display = isDark ? 'none' : '';
                    }
                    if (darkIcon) {
                        darkIcon.classList.toggle('hidden', !isDark);
                        darkIcon.style.display = isDark ? '' : 'none';
                    }
                };

                updateToggleState(root.classList.contains('dark'));

                toggle.addEventListener('click', function () {
                    // Prevent toggling if dark mode is disabled
                    if (!darkModeEnabled) {
                        return;
                    }

                    var nextMode = root.classList.contains('dark') ? 'light' : 'dark';
                    var isDark = applyMode(nextMode, true);
                    updateToggleState(isDark);
                });
            });
        })();
    </script>
    {# tracking services, custom css feature. #}
    {% hook 'head:end' %}
</head>

{# bg-light-background dark:bg-dark-background  #}
<body id="app" class=" 

bg-light-background dark:bg-dark-background 
overflow-x-hidden {% hook 'body:classes' %}
  {{ theme.settings.get('footer_is_dark') ? ' footer-is-dark' : ' footer-is-light' }}
  {{ theme.settings.get('topnav_is_dark') ? ' topnav-is-dark' : '' }}
  {{ theme.settings.get('sticky_add_to_cart') ? ' is-sticky-product-bar' : '' }}
  {{ theme.settings.get('product_card_border_animation', true) ? '' : ' no-card-border-animation' }}
  ">
  <div class="loader-init"></div>
<noscript>
    To get full functionality of this site you need to enable JavaScript. Here is how
    <a href="https://www.enable-javascript.com/" rel="noreferrer"
       target="_blank">To enable JavaScript on webpage</a>.
</noscript>
{% set announcement_bar_position = theme.settings.get('announcement_bar_position', 'top') %}
<div class="app-inner flex flex-col min-h-full">
    {% hook 'body:start' %}
    {% if announcement_bar_position == 'top' %}{% include 'pages.partials.announcement-bar' %}{% endif %}
    {% component 'header.header' %}
    {# under_header: every page. under_carousel: home page renders it inside the
       enhanced-image-carousel component, every other page falls back here. #}
    {% if announcement_bar_position == 'under_header' or (announcement_bar_position == 'under_carousel' and not is_page('index')) %}{% include 'pages.partials.announcement-bar' %}{% endif %}
    {% block content %}{% endblock %}
    {% if announcement_bar_position == 'above_footer' %}{% include 'pages.partials.announcement-bar' %}{% endif %}
    {% component 'footer.footer' %}
</div>
{% hook 'body:end' %}
<script defer src="{{ 'app.js' | asset }}"></script>

{# Twilight Components #}
<salla-offer-modal></salla-offer-modal>
<salla-search></salla-search>

{% if user.type=='guest' %}
    <salla-login-modal></salla-login-modal>
{% endif %}
{% block scripts %}{% endblock %}

