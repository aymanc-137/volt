  {# Scroll to Top Button #}
  {% if is_scroll_enable %}
  <button id="scroll-to-top" class="scroll-button" aria-label="{{ theme.is_rtl ? 'العودة للأعلى' : 'Scroll to top' }}">
    <svg class="progress-ring" width="48" height="48" aria-hidden="true">
      <circle class="progress-ring__circle" stroke="currentColor" stroke-width="4" fill="transparent" r="18" cx="24" cy="24"/>
