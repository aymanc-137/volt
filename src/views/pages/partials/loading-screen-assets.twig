<!-- To eliminate all render blocking CSS & JS and start with the critical css-->
<!-- To show loader to the user till the page content are  loaded-->
<style>
  .loader-init {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: white;
      transition: opacity 0.75s, visibility 0.75s;
      z-index: 9999;
      overflow: hidden;
  }

  .loader-init--hidden {
      opacity: 0;
      visibility: hidden;
  }

  /* Default spinner — shown when no logo is configured */
  .loader-init::after {
      content: "";
      width: 36px;
      height: 36px;
      border: 3px solid #eee;
      border-top-color: #5bd5c4;
      border-radius: 50%;
      animation: loading 0.75s ease infinite;
      position: relative;
      z-index: 1;
  }
  /* Hide the spinner when a logo is shown instead */
  .loader-init--has-logo::after { content: none; }

  /* Blurred background: a soft diagonal wash of the theme colours over the chosen
     background colour. No hard shapes — it stays a smooth gradient, and the logo
     (or spinner) sits above it on the frosted veil. */
  .loader-blur-bg {
      position: absolute;
      inset: -20%;
      z-index: 0;
      background-image: linear-gradient(135deg,
          var(--color-primary, #5bd5c4) 0%,
          var(--color-scandary, #FF3B3B) 55%,
          var(--color-primary-light, var(--color-primary, #5bd5c4)) 100%);
      filter: blur(80px) saturate(140%);
      opacity: .45;
  }
  /* Frosted glass layer: pulls the wash back toward the chosen background colour
     so the logo stays crisp and readable on top of it. */
  .loader-blur-veil {
      position: absolute;
      inset: 0;
      z-index: 0;
      background: inherit;
      opacity: .45;
      -webkit-backdrop-filter: blur(20px);
              backdrop-filter: blur(20px);
  }

  /* Store logo */
  .loader-logo {
      width: auto;
      height: auto;
      max-width: 140px;
      max-height: 140px;
      object-fit: contain;
      position: relative;
      z-index: 1;
  }

  @keyframes loading {
      from {
        transform: rotate(0turn);
      }
      to {
        transform: rotate(1turn);
      }
  }
</style>
<script>
  window.addEventListener("load", () => {
    const loader = document.querySelector(".loader-init");
    loader?.classList.add("loader-init--hidden");
    loader?.addEventListener("transitionend", () => {
  if (!document.querySelector(".loader-init")) return;
      document.body.removeChild(loader);
      });
  });
</script>