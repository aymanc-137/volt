<!-- To eliminate all render blocking CSS & JS and start with the critical css-->
<!-- To show loader to the user till the page content are  loaded-->
<style>
  .loader-init {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: white;
      transition: opacity 0.75s, visibility 0.75s;
      z-index: 9999;
      overflow: hidden;
  }

  .loader-init--hidden {
      opacity: 0;
      visibility: hidden;
  }

  /* Default spinner — shown when no logo is configured */
  .loader-init::after {
      content: "";
      width: 36px;
      height: 36px;
      border: 3px solid #eee;
      border-top-color: #5bd5c4;
      border-radius: 50%;
      animation: loading 0.75s ease infinite;
      position: relative;
      z-index: 1;
  }
  /* Hide the spinner when a logo is shown instead */
  .loader-init--has-logo::after { content: none; }

  /* Blurred background: large, heavily blurred fields that drift slowly, drawn over
     the chosen background colour. Sits under the logo/spinner. */
  .loader-blur-bg {
      position: absolute;
      inset: -35%;
      z-index: 0;
      background-color: transparent;
      background-image:
          radial-gradient(80% 90% at 18% 22%, var(--color-primary, #5bd5c4) 0%, transparent 100%),
          radial-gradient(85% 95% at 82% 30%, var(--color-scandary, #FF3B3B) 0%, transparent 100%),
          radial-gradient(90% 95% at 45% 90%, var(--color-primary-light, #5bd5c4) 0%, transparent 100%);
      filter: blur(90px) saturate(130%);
      opacity: .7;
      animation: loader-blur-drift 9s ease-in-out infinite alternate;
  }

  /* Colourless blur has no background-colour setting: it uses a neutral base that
     follows the dark-mode class (already set on <html> by the head script). */
  .loader-init--plain { background: #f2f3f5; }
  html.dark .loader-init--plain { background: #171717; }

  /* Colourless variant: the same soft depth with no hue at all — neutral light and
     shadow only, so it frosts the neutral base above. */
  .loader-blur-bg--plain {
      background-image:
          radial-gradient(80% 90% at 18% 22%, rgba(255, 255, 255, .22) 0%, transparent 100%),
          radial-gradient(85% 95% at 82% 30%, rgba(0, 0, 0, .20) 0%, transparent 100%),
          radial-gradient(90% 95% at 45% 90%, rgba(255, 255, 255, .16) 0%, transparent 100%);
      filter: blur(90px) grayscale(1);
      opacity: 1;
  }

  @keyframes loader-blur-drift {
      from { transform: scale(1) translate3d(0, 0, 0); }
      to   { transform: scale(1.15) translate3d(2%, -2%, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
      .loader-blur-bg { animation: none; }
  }

  /* Store logo */
  .loader-logo {
      width: auto;
      height: auto;
      max-width: 140px;
      max-height: 140px;
      object-fit: contain;
      position: relative;
      z-index: 1;
  }

  @keyframes loading {
      from {
        transform: rotate(0turn);
      }
      to {
        transform: rotate(1turn);
      }
  }
</style>
<script>
  window.addEventListener("load", () => {
    const loader = document.querySelector(".loader-init");
    loader?.classList.add("loader-init--hidden");
    loader?.addEventListener("transitionend", () => {
  if (!document.querySelector(".loader-init")) return;
      document.body.removeChild(loader);
      });
  });
</script>